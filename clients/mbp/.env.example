# Bridge endpoint (from voice_bridge on Mac mini)
OPENCLAW_WEBHOOK_URL=http://<mac-mini-lan-ip>:18790/voice

# Shared secret — must match OPENCLAW_BEARER_TOKEN on bridge side
OPENCLAW_BEARER_TOKEN=your-shared-secret-here

# Token for the playback server — must match PLAYBACK_BEARER_TOKEN on bridge
PLAYBACK_BEARER_TOKEN=your-playback-secret-here

# Source identifier for routing
CLIENT_SOURCE_NAME=mbp-dev

# Playback server listen port
PLAYBACK_PORT=18780
