# Bridge endpoint
BRIDGE_URL=http://<mac-mini-lan-ip>:18790/voice

# Shared secret — must match BRIDGE_AUTH_TOKEN on bridge side
BRIDGE_AUTH_TOKEN=your-shared-secret-here

# Token for the playback server
CLIENT_PLAYBACK_TOKEN=your-playback-secret-here

# Source identifier for routing
SOURCE_ID=pi-livingroom

# Playback server listen port
PLAYBACK_PORT=18780

# Pi-specific audio config
# Run `arecord -l` to find your mic device index
INPUT_DEVICE_INDEX=3

# Run `aplay -L` to find your playback device
ALSA_PLAYBACK_DEVICE=plughw:3,0
