# HTTP server
BRIDGE_PORT=18790  # Bridge listen port
BRIDGE_TOKEN=<set-a-random-bearer-token>  # Shared bearer token for POST /voice from clients

# Groq speech-to-text
GROQ_API_KEY=<your-groq-api-key>  # Create in the Groq console
GROQ_BASE_URL=https://api.groq.com/openai/v1  # Usually unchanged

# OpenClaw Chat Completions API (synchronous agent turns)
OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions  # Local OpenClaw Gateway endpoint
OPENCLAW_API_TOKEN=<your-openclaw-gateway-token>  # From gateway.auth.token in your OpenClaw config
OPENCLAW_MODEL=openclaw/ceo  # Agent/model route to call
OPENCLAW_USER=voice-client  # Stable user/session identifier

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>  # Create in the ElevenLabs dashboard
ELEVENLABS_VOICE_ID=<your-elevenlabs-voice-id>  # Example: a Sarah-style voice ID from ElevenLabs

# TTS provider: "grok" or "elevenlabs"
TTS_PROVIDER=grok  # Select which TTS backend the bridge should use

# Grok TTS (xAI)
GROK_API_KEY=<your-xai-api-key>  # Create in the xAI console if using GROK TTS
GROK_TTS_VOICE=sal  # Voice ID supported by the xAI TTS endpoint
GROK_TTS_LANGUAGE=de  # Output language code

# Agent timeout (seconds)
AGENT_TIMEOUT_SECONDS=120  # Max wait for OpenClaw reply before failing the turn

# Client routing: source name → playback URL
CLIENT_ROUTES={"mbp-dev":"http://<mbp-host-or-ip>:18780/play","pi-livingroom":"http://<pi-host-or-ip>:18780/play"}  # JSON map used for reply routing
CLIENT_PLAYBACK_TOKEN=<set-a-random-playback-token>  # Shared bearer token for POST /play to client playback servers
